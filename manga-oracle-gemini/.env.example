# Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Affiliate IDs used by /api/out
# Amazon Associates Japan tracking ID, for example: example-22
AMAZON_ASSOCIATE_TAG=your_amazon_associate_tag_here

# Optional. Amazon Product Advertising API credentials used by /api/cover.
AMAZON_PAAPI_ACCESS_KEY=your_amazon_paapi_access_key_here
AMAZON_PAAPI_SECRET_KEY=your_amazon_paapi_secret_key_here

# Optional. Use only if your Rakuten affiliate setup supports direct affiliateId parameters.
RAKUTEN_AFFILIATE_ID=your_rakuten_affiliate_id_here

# Optional. Rakuten affiliate redirect base used by /api/out.
RAKUTEN_AFFILIATE_BASE=https://hb.afl.rakuten.co.jp/ichiba/your_affiliate_base/

# Optional. BookLive / ValueCommerce MyLink base URL used by /api/out.
BOOKLIVE_AFFILIATE_BASE=https://ck.jp.ap.valuecommerce.com/servlet/referral?sid=your_sid&pid=your_pid

# BookLive covers are stored as verified product-link overrides in src/data/bookliveCoverOverrides.js.

# Rakuten Web Service application ID used by /api/cover
RAKUTEN_APP_ID=your_rakuten_app_id_here

# Rakuten Web Service access key used by /api/cover
RAKUTEN_ACCESS_KEY=your_rakuten_access_key_here

# Public site URL used as the Rakuten API referer
SITE_URL=https://www.mangamatchquiz.com/

# Contact form mail settings
# Use a Gmail app password, not your normal Google account password.
CONTACT_EMAIL=mangamatchquiz@gmail.com
GMAIL_SMTP_USER=mangamatchquiz@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
